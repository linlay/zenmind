# Runtime env contract for repo root or packaged release root.
# Copy to `.env`, then edit values for your machine or deployment target.

# Network
# Used by local development and packaged release.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=11937
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=11947

# Optional external YAML overrides.
# Default structured config lives at `configs/application.yml`.
# Copy `configs/application.example.yml` to `configs/application.yml` when needed.
# Local backend run from `backend/` auto-loads ../configs/application.yml.
# Docker Compose default:           fixed in docker-compose.yml
# Packaged release default:        auto-loads ./configs/application.yml
# Optional override file:          CONFIG_PATH=./configs/config.prod.yml
# CONFIG_PATH=
#
# Copilot runner agents are configured separately in `configs/agents.yml`.
# Copy `configs/agents.example.yml` to `configs/agents.yml` when you want
# runner-backed agents to appear in the Copilot selector.

# Copilot runner
COPILOT_RUNNER_BASE_URL=http://127.0.0.1:11949
COPILOT_RUNNER_TIMEOUT_SECONDS=60
COPILOT_RUNNER_AUTHORIZATION_BEARER=

# Web auth
AUTH_ENABLED=true
AUTH_USERNAME=admin
# Generate bcrypt hash:
# htpasswd -nbBC 10 '' 'change-this-password' | cut -d: -f2
# Required when AUTH_ENABLED=true.
AUTH_PASSWORD_HASH_BCRYPT='$2y$10$Lpy241UWfq8U4oMW9cPNSOs5lkd6wZRyWF3wNnPm0Jkg9.LEvdbx6'
AUTH_SESSION_TTL_SECONDS=43200
AUTH_LOGIN_RATE_LIMIT_ENABLED=true
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10

# App JWT auth
APP_AUTH_ENABLED=true
# Copy `configs/local-public-key.example.pem` to `configs/local-public-key.pem` first.
# Relative paths are resolved from the `.env` directory.
APP_AUTH_LOCAL_PUBLIC_KEY_FILE=./configs/local-public-key.pem
# Optional fallback when APP_AUTH_LOCAL_PUBLIC_KEY_FILE is empty.
APP_AUTH_JWKS_URI=
# Must exactly match the JWT `iss` claim. Replace this placeholder with your real issuer.
APP_AUTH_ISSUER=https://replace-with-your-issuer.example.com
APP_AUTH_JWKS_CACHE_SECONDS=300
# Must match the JWT `aud` claim. Leave blank when tokens do not carry `aud`.
APP_AUTH_AUDIENCE=
APP_AUTH_CLOCK_SKEW_SECONDS=30

# Terminal files
TERMINAL_FILES_ENABLED=true

# SSH
TERMINAL_SSH_CREDENTIALS_FILE=data/ssh-credentials.json
TERMINAL_SSH_MASTER_KEY=replace_with_a_random_secret

# Frontend-only build/runtime variables
VITE_API_BASE=
VITE_COPILOT_REFRESH_MS=2000
